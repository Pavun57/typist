{
  "name": "typist",
  "version": "0.1.1",
  "description": "Push-to-talk multilingual voice typing — cloud (Sarvam) or offline (local Whisper) speech-to-text",
  "author": {
    "name": "Pavun",
    "email": "rpavun57@gmail.com"
  },
  "homepage": "https://github.com/Pavun57/typist",
  "main": "./out/main/index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.typist.app",
    "productName": "Typist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "resources/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Pavun <rpavun57@gmail.com>"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Typist needs microphone access to transcribe your speech."
      }
    },
    "publish": {
      "provider": "github",
      "owner": "Pavun57",
      "repo": "typist"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "sherpa-onnx-node": "^1.13.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  }
}
